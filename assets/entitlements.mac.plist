<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Electron apps under hardened runtime. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Required because Companion spawns the OpenClaw Node gateway as a child process. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for better-sqlite3 / sqlite-vec native modules. -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Outbound network (Ollama localhost, OpenAI/Anthropic if configured, etc.). -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Inbound network for the OpenClaw gateway listening on 18789. -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for workspace operations (memory, journals, plugins). -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
